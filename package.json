{
  "name": "ln-link-app",
  "version": "1.1.1",
  "description": "Lightning Network Node Application built with Electron",
  "main": "src/main.js",
  "scripts": {
    "prisma:generate": "node ./scripts/prisma-setup.js --step=generate",
    "prisma:migrate": "node ./scripts/prisma-setup.js --step=migrate",
    "prisma:setup": "node ./scripts/prisma-setup.js",
    "dev": "node ./scripts/prisma-setup.js && electron . --dev",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac --arm64 --publish=never",
    "build:mac-arm": "electron-builder --mac --arm64 --publish=never",
    "build:win": "electron-builder --win --publish=never",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --publish=never",
    "postinstall": "electron-builder install-app-deps",
    "prebuild": "node ./scripts/prebuild-clean-data.js && node ./scripts/prisma-setup.js",
    "test:rgb-version": "node ./scripts/test-rgb-version-checker.js"
  },
  "keywords": [
    "electron",
    "lightning",
    "bitcoin",
    "node",
    "lnd"
  ],
  "author": "Lnfi-Network",
  "license": "MIT",
  "devDependencies": {
    "asar": "^3.2.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "dependencies": {
    "@prisma/client": "6.14.0",
    "detect-port": "^1.5.1",
    "dotenv": "^17.2.3",
    "electron-log": "^5.4.0",
    "electron-store": "^8.1.0",
    "lnlink-server": "1.2.3",
    "nostr-tools": "1.17.0",
    "prisma": "6.14.0",
    "ps-list": "^7.2.0"
  },
  "build": {
    "appId": "node.lnfi.network",
    "productName": "NodeFlow",
    "publish": null,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "!bin/**",
      "rgb-compat.json",
      ".env",
      {
        "from": "node_modules/.prisma",
        "to": "node_modules/.prisma",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "data/.link",
        "to": "data/.link",
        "filter": [
          "lnlink.db"
        ]
      }
    ],
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "buildDependenciesFromSource": false,
    "asar": true,
    "asarUnpack": [
      "node_modules/.prisma/client/**",
      "node_modules/@prisma/client/**",
      "node_modules/lnlink-server/prisma/**",
      "node_modules/@nodeflow-network/**"
    ],
    "afterSign": "scripts/afterSign.js",
    "mac": {
      "category": "public.app-category.finance",
      "icon": "assets/icon.icns",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "assets/logo100.svg",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "assets/logo100.svg",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "afterPack": "./afterPack.js"
  }
}
