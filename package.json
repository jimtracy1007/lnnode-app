{
  "name": "LNLink",
  "version": "0.1.1-alpha.1",
  "description": "Lightning Network Node Application built with Electron",
  "main": "src/main.js",
  "scripts": {
    "preinstall": "node ./scripts/fetch-binaries.js --all",
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac --x64 --arm64 --publish=never",
    "build:mac-amd": "npm run rebuild:x64 && electron-builder --mac --x64 --publish=never",
    "build:mac-arm": "npm run rebuild:arm64 && electron-builder --mac --arm64 --publish=never",
    "build:win": "npm run rebuild:win:x64 && electron-builder --win --publish=never",
    "build:linux": "electron-builder --linux --publish=never",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --publish=never",
    "postinstall": "electron-builder install-app-deps",
    "rebuild:x64": "electron-rebuild --arch=x64",
    "rebuild:arm64": "electron-rebuild --arch=arm64",
    "rebuild:win:x64": "electron-rebuild --arch=x64 --platform=win32"
  },
  "keywords": [
    "electron",
    "lightning",
    "bitcoin",
    "node",
    "lnd"
  ],
  "author": "Lnfi-Network",
  "license": "MIT",
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "@lnfi-network/ln-link": "*",
    "electron-log": "^5.4.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7",
    "nostr-tools": "1.17.0"
  },
  "build": {
    "appId": "node.lnfi.network",
    "productName": "LN-Link",
    "publish": null,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "buildDependenciesFromSource": false,
    "asar": true,
    "mac": {
      "category": "public.app-category.finance",
      "icon": "assets/lnfi.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "identity": null,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        }
      ],
      "extraFiles": [
        {
          "from": "bin/darwin-${arch}/",
          "to": "Resources/bin/darwin-${arch}/",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "win": {
      "icon": "assets/lnfi.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "extraFiles": [
        {
          "from": "bin/win-${arch}/",
          "to": "Resources/bin/win-${arch}/",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "linux": {
      "icon": "assets/lnfi.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "afterPack": "./afterPack.js"
  }
}
