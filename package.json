{
  "name": "ln-link-app",
  "version": "1.0.0-alpha.3",
  "description": "Lightning Network Node Application built with Electron",
  "main": "src/main.js",
  "scripts": {
    "preinstall": "node ./scripts/fetch-binaries.js",
    "prisma:generate": "node ./scripts/prisma-setup.js --step=generate",
    "prisma:migrate": "node ./scripts/prisma-setup.js --step=migrate",
    "prisma:setup": "node ./scripts/prisma-setup.js",
    "dev": "node ./scripts/prisma-setup.js && electron . --dev",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac --x64 --arm64 --publish=never",
    "build:mac-amd": "electron-builder --mac --x64 --publish=never",
    "build:mac-arm": "electron-builder --mac --arm64 --publish=never",
    "build:win": "electron-builder --win --publish=never",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --publish=never",
    "postinstall": "electron-builder install-app-deps",
    "prebuild": "node ./scripts/prisma-setup.js"
  },
  "keywords": [
    "electron",
    "lightning",
    "bitcoin",
    "node",
    "lnd"
  ],
  "author": "Lnfi-Network",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "detect-port": "^1.5.1",
    "electron-log": "^5.4.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7",
    "ln-link": "1.0.8-alpha",
    "nostr-tools": "1.17.0",
    "ps-list": "^7.2.0"
  },
  "build": {
    "appId": "node.lnfi.network",
    "productName": "LN-Link",
    "publish": null,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      {
        "from": "node_modules/.prisma",
        "to": "node_modules/.prisma",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "data",
        "to": "data",
        "filter": [
          "**/*"
        ]
      }
    ],
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "buildDependenciesFromSource": false,
    "asar": false,
    "mac": {
      "category": "public.app-category.finance",
      "icon": "assets/lnfi.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "identity": null,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        }
      ],
      "extraFiles": [
        {
          "from": "bin/darwin-${arch}/",
          "to": "Resources/bin/darwin-${arch}/",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "win": {
      "icon": "assets/lnfi.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "extraFiles": [
        {
          "from": "bin/win-${arch}/",
          "to": "Resources/bin/win-${arch}/",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "linux": {
      "icon": "assets/lnfi.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "extraFiles": [
        {
          "from": "bin/linux-${arch}/",
          "to": "Resources/bin/linux-${arch}/",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "afterPack": "./afterPack.js"
  }
}
